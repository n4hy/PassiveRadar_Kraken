- name: kraken_passive_radar_aoa_estimator_0
  id: kraken_passive_radar_aoa_estimator
  parameters:
    affinity: ''
    alias: ''
    algorithm: '0'
    array_type: '0'
    comment: 'AoA Estimator


      Bartlett beamforming for angle-of-arrival

      Inputs: 4 CAF channels + detections from clustering

      Output: AoA-augmented detections (12 floats/det)'
    d_lambda: '0.5'
    max_detections: '1000'
    maxoutbuf: '0'
    min_angle_deg: '-90.0'
    max_angle_deg: '90.0'
    minoutbuf: '0'
    n_angles: '181'
    n_snapshots: '16'
    n_sources: '1'
    num_doppler_bins: doppler_len
    num_elements: '4'
    num_range_bins: cpi_len
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1624, 388]
    rotation: 0
    state: enabled

- name: kraken_passive_radar_tracker_0
