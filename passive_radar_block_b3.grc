  parameters:
    affinity: ''
    alias: ''
    comment: 'Multi-Target Tracker


      Kalman filter with GNN data association

      Input: AoA-augmented detections (12 floats/det) from AoA Estimator'
    confirm_hits: '3'
    delete_misses: '5'
    dt: '0.1'
    gate_threshold: '9.21'
    max_detections: '1000'
    max_tracks: '50'
    maxoutbuf: '0'
    meas_noise_doppler: '2.0'
    meas_noise_range: '100.0'
    minoutbuf: '0'
    process_noise_doppler: '5.0'
    process_noise_range: '50.0'
  states:
