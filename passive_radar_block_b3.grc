      Groups detections into targets'
    doppler_resolution_hz: samp_rate / (cpi_len * doppler_len)
    max_cluster_extent: '50'
    max_detections: '1000'
    maxoutbuf: '0'
    minoutbuf: '0'
    min_cluster_size: '3'
    num_doppler_bins: doppler_len
    num_range_bins: cpi_len
    range_resolution_m: 3e8 / (2 * samp_rate)
  states:
    bus_sink: false
