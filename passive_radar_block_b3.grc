options:
  parameters:
    author: Dr Robert W McGwier, PhD
    catch_exceptions: 'True'
    category: '[Kraken Passive Radar]'
    cmake_opt: ''
    comment: ''
    copyright: '2026'
    description: 'Passive Radar with Block B3 Reference Signal Reconstruction'
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: .
    id: passive_radar_block_b3
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Passive Radar with Block B3
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: b3_fft_size
  id: variable
  parameters:
    comment: ''
    value: '8192'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [400, 12]
    rotation: 0
    state: enabled

- name: b3_guard_interval
  id: variable
  parameters:
    comment: ''
    value: '192'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [520, 12]
    rotation: 0
    state: enabled

- name: b3_signal_type
  id: variable
  parameters:
    comment: 'Options: passthrough, fm, atsc3, dvbt'
    value: '"fm"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [272, 12]
    rotation: 0
    state: enabled

- name: cpi_len
  id: variable
  parameters:
    comment: ''
    value: '4096'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [184, 76]
    rotation: 0
    state: enabled

- name: doppler_len
  id: variable
  parameters:
    comment: ''
    value: '64'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [272, 76]
    rotation: 0
    state: enabled

- name: freq
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 0,0,1,1
    label: Center Frequency (Hz)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: 24e6
    step: 1e6
    stop: 1.8e9
    value: 100e6
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [664, 12]
    rotation: 0
    state: enabled

- name: gain
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 0,1,1,1
    label: Gain (dB)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '1'
    stop: '49'
    value: '30'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [816, 12]
    rotation: 0
    state: enabled

- name: num_surv
  id: variable
  parameters:
    comment: ''
    value: '4'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [376, 76]
    rotation: 0
    state: enabled

- name: num_taps
  id: variable
  parameters:
    comment: ''
    value: '128'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [464, 76]
    rotation: 0
    state: enabled

- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: 2.4e6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [184, 12]
    rotation: 0
    state: enabled

- name: kraken_passive_radar_dvbt_reconstructor_0
  id: kraken_passive_radar_dvbt_reconstructor
  parameters:
    affinity: ''
    alias: ''
    audio_bw: 15e3
    code_rate: '2'
    comment: 'Block B3: Reference Signal Reconstructor


      Reconstructs clean reference signal from noisy broadcast


      Expected: 10-20 dB SNR improvement'
    constellation: '2'
    enable_pilot_regen: 'True'
    enable_stereo: 'True'
    enable_svd: 'True'
    fft_size: b3_fft_size
    fm_deviation: 75e3
    guard_interval: b3_guard_interval
    maxoutbuf: '0'
    minoutbuf: '0'
    pilot_pattern: '0'
    signal_type: b3_signal_type
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [624, 340]
    rotation: 0
    state: enabled

