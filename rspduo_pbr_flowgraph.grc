- name: rspduo_src
  id: kraken_passive_radar_rspduo_source
  parameters:
    affinity: ''
    alias: ''
    am_notch: 'False'
    bandwidth: '0'
    bias_t: 'False'
    comment: 'RSPduo Dual-Tuner Coherent Source

      Output 0: Reference (Tuner 1)

      Output 1: Surveillance (Tuner 2)

      Coherent clock - no phase calibration needed'
    dab_notch: 'False'
    frequency: center_freq
    if_gain: if_gain
    maxoutbuf: '0'
    minoutbuf: '0'
    rf_gain: rf_gain_reduction
    rf_notch: 'False'
    sample_rate: samp_rate
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [133.75, 727.5]
    rotation: 0
    state: enabled
- name: s2v_ref
  id: blocks_stream_to_vector
  parameters:
    affinity: ''
    alias: ''
    comment: 'Reference: stream to CPI vectors'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: cpi_samples
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1440, 100]
    rotation: 0
    state: enabled
- name: s2v_ref_conj
  id: blocks_stream_to_vector
  parameters:
    affinity: ''
    alias: ''
    comment: S2V after conjugate
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: fft_size
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2200, 36]
    rotation: 0
    state: enabled
- name: s2v_surv
  id: blocks_stream_to_vector
  parameters:
    affinity: ''
    alias: ''
    comment: 'Cleaned surv: stream to CPI vectors'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: cpi_samples
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1440, 220]
    rotation: 0
    state: enabled
- name: v2s_ref_for_conj
  id: blocks_vector_to_stream
  parameters:
    affinity: ''
    alias: ''
    comment: V2S for element-wise conjugate
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: fft_size
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1840, 36]
    rotation: 0
    state: enabled

connections:
- [agc_ref, '0', eca_canceller, '0']
- [agc_ref, '0', s2v_ref, '0']
- [agc_surv, '0', eca_canceller, '1']
- [conjugate_ref, '0', s2v_ref_conj, '0']
- [dc_blocker_ref, '0', freq_xlating_fir_ref, '0']
- [dc_blocker_surv, '0', freq_xlating_fir_surv, '0']
- [doppler_proc, '0', nlog10_rd, '0']
- [eca_canceller, '0', s2v_surv, '0']
- [fft_ref, '0', v2s_ref_for_conj, '0']
- [fft_surv, '0', multiply_surv, '0']
- [freq_xlating_fir_ref, '0', agc_ref, '0']
- [freq_xlating_fir_surv, '0', agc_surv, '0']
- [ifft_surv, '0', doppler_proc, '0']
- [multiply_surv, '0', ifft_surv, '0']
- [nlog10_rd, '0', qtgui_vector_sink_rd, '0']
- [rspduo_src, '0', dc_blocker_ref, '0']
- [rspduo_src, '0', qtgui_freq_sink_ref, '0']
- [rspduo_src, '1', dc_blocker_surv, '0']
- [rspduo_src, '1', qtgui_freq_sink_surv, '0']
- [s2v_ref, '0', fft_ref, '0']
- [s2v_ref_conj, '0', multiply_surv, '1']
- [s2v_surv, '0', fft_surv, '0']
- [v2s_ref_for_conj, '0', conjugate_ref, '0']

metadata:
  file_format: 1
  grc_version: 3.10.12.0
