options:
  parameters:
    author: N4HY
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: '2026'
    description: Passive Bistatic Radar using RSPduo dual-tuner (coherent clock, no
      phase calibration needed)
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: rspduo_pbr_flowgraph
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: RSPduo Passive Radar - Range-Doppler
    window_size: (1920,1080)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: center_freq
  id: variable
  parameters:
    comment: FM station frequency
    value: 103.7e6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 320]
    rotation: 0
    state: enabled
- name: cpi_samples
  id: variable
  parameters:
    comment: CPI length in samples (= fft_size)
    value: '2048'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 640]
    rotation: 0
    state: enabled
- name: decimated_rate
  id: variable
  parameters:
    comment: Post-decimation sample rate
    value: int(samp_rate / decimation)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 560]
    rotation: 0
    state: enabled
- name: decimation
  id: variable
  parameters:
    comment: Decimation factor
    value: int(samp_rate / signal_bw)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 480]
    rotation: 0
    state: enabled
- name: eca_reg
  id: variable
  parameters:
    comment: ECA regularization factor
    value: '0.0001'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 880]
    rotation: 0
    state: enabled
- name: eca_taps
  id: variable
  parameters:
    comment: ECA filter taps
    value: '256'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 800]
    rotation: 0
    state: enabled
- name: fft_size
  id: variable
  parameters:
    comment: FFT size for cross-correlation
    value: '2048'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 720]
    rotation: 0
    state: enabled
- name: if_gain
  id: variable
  parameters:
    comment: RSPduo IF gain (20-59 dB)
    value: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 400]
    rotation: 0
    state: enabled
- name: lpf_taps
  id: variable
  parameters:
    comment: Low-pass filter taps for decimation
    value: firdes.low_pass(1.0, samp_rate, signal_bw/2, signal_bw/10, window.WIN_HAMMING)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [160, 160]
    rotation: 0
    state: enabled
- name: num_doppler_bins
  id: variable
  parameters:
    comment: Number of CPIs for Doppler FFT
    value: '64'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [160, 240]
    rotation: 0
    state: enabled
- name: rd_size
  id: variable
  parameters:
    comment: Range-Doppler map total size
    value: num_doppler_bins * fft_size
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [160, 320]
    rotation: 0
    state: enabled
- name: rf_gain_reduction
  id: variable
  parameters:
    comment: RSPduo RF gain reduction (0-27 dB)
    value: '0.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [160, 400]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: RSPduo dual-tuner max 2 MHz
    value: '2000000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 160]
    rotation: 0
    state: enabled
- name: signal_bw
  id: variable
  parameters:
    comment: Signal bandwidth of interest
    value: '250000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 240]
    rotation: 0
    state: enabled
- name: agc_ref
  id: analog_agc2_xx
  parameters:
    affinity: ''
    alias: ''
    attack_rate: '0.01'
    comment: Reference AGC
    decay_rate: '0.001'
    gain: '1.0'
    max_gain: '65536'
    maxoutbuf: '0'
    minoutbuf: '0'
    reference: '1.0'
    type: complex
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1000, 104]
    rotation: 0
    state: enabled
- name: agc_surv
  id: analog_agc2_xx
  parameters:
    affinity: ''
    alias: ''
    attack_rate: '0.01'
    comment: Surveillance AGC
    decay_rate: '0.001'
    gain: '1.0'
    max_gain: '65536'
    maxoutbuf: '0'
    minoutbuf: '0'
    reference: '1.0'
    type: complex
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1000, 220]
    rotation: 0
    state: enabled
- name: conjugate_ref
  id: blocks_conjugate_cc
  parameters:
    affinity: ''
    alias: ''
    comment: Conjugate reference spectrum
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2040, 44]
    rotation: 0
    state: enabled
- name: dc_blocker_ref
  id: dc_blocker_xx
  parameters:
    affinity: ''
    alias: ''
    comment: Reference channel DC block
    length: '32'
    long_form: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    type: cc
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [560, 132]
    rotation: 0
    state: enabled
- name: dc_blocker_surv
  id: dc_blocker_xx
  parameters:
    affinity: ''
    alias: ''
    comment: Surveillance channel DC block
    length: '32'
    long_form: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    type: cc
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [560, 232]
    rotation: 0
    state: enabled
- name: doppler_proc
  id: kraken_passive_radar_doppler_processor
  parameters:
    affinity: ''
    alias: ''
    comment: 'Slow-time FFT for Range-Doppler map

      Accumulates 64 CPIs then FFT across slow-time'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_doppler_bins: num_doppler_bins
    num_range_bins: fft_size
    output_power: 'True'
    window_type: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2440, 168]
    rotation: 0
    state: enabled
- name: eca_canceller
  id: kraken_passive_radar_eca_canceller
  parameters:
    affinity: ''
    alias: ''
    comment: 'ECA-B Clutter Cancellation

      1 ref + 1 surv -> 1 cleaned surv'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_surv: '1'
    num_taps: eca_taps
    reg_factor: eca_reg
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1240, 180]
    rotation: 0
    state: enabled
- name: fft_ref
  id: fft_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: Reference FFT for CAF
    fft_size: fft_size
    forward: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    nthreads: '1'
    shift: 'False'
    type: complex
    window: '[]'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1640, 88]
    rotation: 0
    state: enabled
- name: fft_surv
  id: fft_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: Surveillance FFT for CAF
    fft_size: fft_size
    forward: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    nthreads: '1'
    shift: 'False'
    type: complex
    window: '[]'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1640, 208]
    rotation: 0
    state: enabled
- name: freq_xlating_fir_ref
  id: freq_xlating_fir_filter_xxx
  parameters:
    affinity: ''
    alias: ''
    center_freq: '0'
    comment: 'Reference: decimate to signal_bw'
    decim: decimation
    maxoutbuf: '0'
    minoutbuf: '0'
    samp_rate: samp_rate
    taps: lpf_taps
    type: ccc
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [760, 112]
    rotation: 0
    state: enabled
- name: freq_xlating_fir_surv
  id: freq_xlating_fir_filter_xxx
  parameters:
    affinity: ''
    alias: ''
    center_freq: '0'
    comment: 'Surveillance: decimate to signal_bw'
    decim: decimation
    maxoutbuf: '0'
    minoutbuf: '0'
    samp_rate: samp_rate
    taps: lpf_taps
    type: ccc
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [760, 212]
    rotation: 0
    state: enabled
- name: ifft_surv
  id: fft_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: IFFT -> Range profile
    fft_size: fft_size
    forward: 'False'
    maxoutbuf: '0'
    minoutbuf: '0'
    nthreads: '1'
    shift: 'False'
    type: complex
    window: '[]'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2240, 180]
    rotation: 0
    state: enabled
- name: multiply_surv
  id: blocks_multiply_xx
  parameters:
    affinity: ''
    alias: ''
    comment: Cross-spectrum surv * conj(ref)
    maxoutbuf: '0'
    minoutbuf: '0'
    num_inputs: '2'
    type: complex
    vlen: fft_size
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2040, 180]
    rotation: 0
    state: enabled
- name: nlog10_rd
  id: blocks_nlog10_ff
  parameters:
    affinity: ''
    alias: ''
    comment: 10*log10 for dB display
    k: '0'
    maxoutbuf: '0'
    minoutbuf: '0'
    n: '10'
    vlen: rd_size
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2640, 180]
    rotation: 0
    state: enabled
- name: note_signal_flow
  id: note
  parameters:
    alias: ''
    comment: 'Signal Flow:


      RSPduo (2ch, coherent clock) -> DC Block -> LPF/Decimate -> AGC -> ECA (1 ref
      + 1 surv) -> S2V -> FFT -> conj(ref)*surv -> IFFT -> Doppler -> dB -> Display


      No phase calibration needed (RSPduo shares a common clock between tuners)'
    note: RSPduo PASSIVE RADAR SIGNAL FLOW
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [320, 8]
    rotation: 0
    state: enabled
- name: qtgui_freq_sink_ref
  id: qtgui_freq_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '1.0'
    alpha10: '1.0'
    alpha2: '1.0'
    alpha3: '1.0'
    alpha4: '1.0'
    alpha5: '1.0'
    alpha6: '1.0'
    alpha7: '1.0'
    alpha8: '1.0'
    alpha9: '1.0'
    autoscale: 'True'
    average: '0.2'
    axislabels: 'True'
    bw: samp_rate
    color1: '"blue"'
    color10: '"dark blue"'
    color2: '"red"'
    color3: '"green"'
    color4: '"black"'
    color5: '"cyan"'
    color6: '"magenta"'
    color7: '"yellow"'
    color8: '"dark red"'
    color9: '"dark green"'
    comment: ''
    ctrlpanel: 'False'
    fc: '0'
    fftsize: '2048'
    freqhalf: 'True'
    grid: 'True'
    gui_hint: 1,0,1,1
    label: Relative Gain
    label1: Ref (Tuner 1)
    label10: ''
    label2: ''
    label3: ''
    label4: ''
    label5: ''
    label6: ''
    label7: ''
    label8: ''
    label9: ''
