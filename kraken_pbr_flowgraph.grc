    coordinate: [1360, 180]
    rotation: 0
    state: enabled
- name: epy_block_phase_corr
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass phase_corrector(gr.sync_block):\n\
      \    \"\"\"\n    Applies phase correction to surveillance channel.\n    Correction\
      \ phasor updated by calibration routine.\n    \"\"\"\n    def __init__(self):\n\
      \        gr.sync_block.__init__(\n            self, name=\"Phase Corrector\"\
      ,\n            in_sig=[np.complex64],\n            out_sig=[np.complex64]\n\
      \        )\n        self.correction = np.complex64(1.0 + 0j)\n\n    def set_correction(self,\
      \ phasor):\n        self.correction = np.complex64(phasor)\n\n    def work(self,\
      \ input_items, output_items):\n        output_items[0][:] = input_items[0] *\
      \ self.correction\n        return len(output_items[0])\n"
    affinity: ''
    alias: ''
    comment: 'Phase Corrector on surveillance channel

      Correction phasor updated by calibration'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('Phase Corrector', 'phase_corrector', [], [('0', 'complex', 1)], [('0',
      'complex', 1)], '\nApplies phase correction to surveillance channel.\nCorrection
      phasor updated by calibration routine.\n', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [960, 220]
    rotation: 0
    state: enabled
